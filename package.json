{
	"name": "@thatskyapplication/markdown-delivery",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "tsc",
		"test": "tsc --noEmit",
		"format": "biome check --write",
		"lint": "biome check",
		"dev": "tsx --env-file=.env source/index.ts",
		"start": "node distribution/index.js",
		"update": "pnpm update --interactive --latest",
		"knip": "knip"
	},
	"dependencies": {
		"discord-api-types": "^0.38.23",
		"discord-delivery": "^1.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.1.3",
		"@types/node": "^26.1.1",
		"knip": "^5.55.1",
		"tsx": "^4.20.3",
		"typescript": "^6.0.3"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=26",
			"onFail": "error"
		},
		"packageManager": {
			"name": "pnpm",
			"version": ">=11.10.0",
			"onFail": "error"
		}
	}
}
